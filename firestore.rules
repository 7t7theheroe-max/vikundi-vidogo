rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function getProfile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin()       { return isSignedIn() && getProfile().role == 'admin' && getProfile().status == 'approved'; }
    function isZoneLeader()  { return isSignedIn() && getProfile().role == 'zone_leader' && getProfile().status == 'approved'; }
    function isGroupLeader() { return isSignedIn() && getProfile().role == 'group_leader' && getProfile().status == 'approved'; }
    function isApproved()    { return isSignedIn() && getProfile().status == 'approved'; }

    // ── users ──
    match /users/{uid} {
      // Anyone signed in can read their own profile; approved zone leaders/admins can read others
      allow read: if isOwner(uid) || isAdmin() || isZoneLeader();
      // Create: only self (on registration)
      allow create: if isOwner(uid);
      // Update: self (limited fields) OR zone_leader (approve/reject group_leaders in same zone) OR admin
      allow update: if isOwner(uid)
        || isAdmin()
        || (isZoneLeader()
            && resource.data.role == 'group_leader'
            && resource.data.zoneId == getProfile().zoneId);
      allow delete: if isAdmin();
    }

    // ── zones ──
    match /zones/{zoneId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── members ──
    match /members/{memberId} {
      // Group leader can read/write their own members; zone leader and admin can read
      allow read:   if isApproved() && (
                      resource.data.leaderId == request.auth.uid
                      || isZoneLeader()
                      || isAdmin()
                    );
      allow create: if isGroupLeader() && request.resource.data.leaderId == request.auth.uid;
      allow update: if isGroupLeader() && resource.data.leaderId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── reports ──
    match /reports/{reportId} {
      // Group leader can read/write their own; zone leader reads zone; admin reads all
      allow read:   if isApproved() && (
                      resource.data.leaderId == request.auth.uid
                      || (isZoneLeader() && resource.data.zoneId == getProfile().zoneId)
                      || isAdmin()
                    );
      allow create: if isGroupLeader() && request.resource.data.leaderId == request.auth.uid;
      allow update: if isAdmin()
        || (isZoneLeader() && resource.data.zoneId == getProfile().zoneId)
        || (isGroupLeader() && resource.data.leaderId == request.auth.uid && resource.data.status == 'draft');
      allow delete: if isAdmin();
    }

    // ── announcements ──
    match /announcements/{annId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── config ──
    match /config/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
  }
}
